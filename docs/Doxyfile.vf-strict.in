# =============================================================================
# Strict, subsystem-scoped Doxygen configuration for the VectorFunction layer.
#
# Configured by CMake into <build-dir>/docs/Doxyfile.vf-strict alongside the
# main Doxyfile. Unlike the permissive base config (which hides undocumented
# entities), this one UN-hides them and treats any undocumented public symbol
# — or any doc error — as a hard failure. It is the enforcement gate for the
# VectorFunction docstring coverage required by the docs plan (Task 8).
#
# It inherits everything from the generated base Doxyfile, then overrides the
# input scope and the warning discipline.
# =============================================================================
@INCLUDE = @CMAKE_CURRENT_BINARY_DIR@/Doxyfile

# Scope: the VF umbrella header + every transitively-owned detail header.
INPUT                  = @PROJECT_SOURCE_DIR@/include/tycho/vector_functions.h \
                         @PROJECT_SOURCE_DIR@/include/tycho/detail/vf
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/doxygen-vf-strict

# Coverage enforcement: surface undocumented entities instead of hiding them,
# then fail on the first missing docstring or doc error.
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS
WARN_LOGFILE           = @CMAKE_CURRENT_BINARY_DIR@/doxygen-vf-strict/warnings.log

# Count @internal-documented helpers as covered. Implementation-detail symbols
# (dispatch traits, *_impl hooks, type-erasure plumbing) carry a docstring whose
# body is wrapped in @internal ... @endinternal so the PUBLISHED docs (base
# Doxyfile, INTERNAL_DOCS=NO) hide them. For the COVERAGE check we must treat
# those as documented — otherwise a fully-documented internal helper would read
# as undocumented. The XML produced here is used only for the gate, never
# published, so surfacing internals here is harmless.
INTERNAL_DOCS          = YES
ENABLED_SECTIONS       = internal

# Exclusions:
#   - Avoid:: is dead test scaffolding (function_templates.h), not public API
#     and not included by any TU.
#   - VF_TYPE_ALIASES is a boilerplate CRTP type-alias macro re-exported by
#     every expression type; expand it away so it is not counted as an
#     undocumented member of each struct.
EXCLUDE_SYMBOLS       += Avoid::*
PREDEFINED            += VF_TYPE_ALIASES(x)=
